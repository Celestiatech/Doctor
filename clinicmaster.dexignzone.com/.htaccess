<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /vishal/temapltes/Doctor/clinicmaster.dexignzone.com/

    # Keep the home route on the default medical demo.
    RewriteRule ^$ index.php?page=medical/index [QSA,L]
    
    # Serve actual files and directories directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Allow /theme/page style URLs, for example /dentist/about-us.
    RewriteRule ^([A-Za-z0-9-]+)/([A-Za-z0-9-]+)/?$ index.php?page=$1/$2 [QSA,L]

    # Allow /theme to open that theme's homepage, for example /dentist.
    RewriteRule ^([A-Za-z0-9-]+)/?$ index.php?page=$1 [QSA,L]
    
    # Fallback to the PHP router for any remaining clean URLs.
    RewriteRule ^(.*)$ index.php?page=$1 [QSA,L]
    
    # Prevent direct access to certain files
    <FilesMatch "\.(env|config|sql)$">
        Order Deny,Allow
        Deny from all
    </FilesMatch>
</IfModule>

# Set proper headers
<IfModule mod_headers.c>
    Header set X-UA-Compatible "IE=edge"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Compression
<IfModule mod_gzip.c>
    mod_gzip_on Yes
    mod_gzip_dechunk Yes
    mod_gzip_item_include file \.(html?|txt|css|js|xml|php)$
    mod_gzip_item_include handler ^cgi-script$
    mod_gzip_item_exclude rspheader ^Content-Encoding:\s*gzip
</IfModule>
