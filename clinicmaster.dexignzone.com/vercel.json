{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.php?page=medical/index"
    },
    {
      "source": "/medical",
      "destination": "/index.php?page=medical/index"
    },
    {
      "source": "/dentist",
      "destination": "/index.php?page=dentist/index"
    },
    {
      "source": "/dieting",
      "destination": "/index.php?page=dieting/index"
    },
    {
      "source": "/fatloss",
      "destination": "/index.php?page=fatloss/index"
    },
    {
      "source": "/gynecology",
      "destination": "/index.php?page=gynecology/index"
    },
    {
      "source": "/ophthalmology",
      "destination": "/index.php?page=ophthalmology/index"
    },
    {
      "source": "/pediatrics",
      "destination": "/index.php?page=pediatrics/index"
    },
    {
      "source": "/plasticsurgery",
      "destination": "/index.php?page=plasticsurgery/index"
    },
    {
      "source": "/skincare",
      "destination": "/index.php?page=skincare/index"
    },
    {
      "source": "/:theme/:page",
      "destination": "/index.php?page=:theme/:page"
    },
    {
      "source": "/:page",
      "destination": "/index.php?page=:page"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
