{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/api/index.php?page=medical/index"
    },
    {
      "src": "/([A-Za-z0-9-]+)/([A-Za-z0-9-]+)",
      "dest": "/api/index.php?page=$1/$2"
    },
    {
      "src": "/([A-Za-z0-9-]+)",
      "dest": "/api/index.php?page=$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php?page=$1"
    }
  ]
}
